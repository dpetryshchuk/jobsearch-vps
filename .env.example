# Apify API token — used by LinkedIn, Indeed, and ZipRecruiter scrapers
# Get it at: apify.com → Settings → Integrations → API tokens
APIFY_API_TOKEN=your_apify_token_here

# Hunter.io API key — for email finder tool (hunter.io → API → copy key)
HUNTER_API_KEY=your_hunter_api_key_here

# nextplay.so Substack authenticated RSS token
# Find it at: https://nextplayso.substack.com/account (look for RSS section)
# OR in your welcome email from nextplay
# Token is the part after ?token= in the RSS URL
NEXTPLAY_RSS_TOKEN=your_token_here

# Your session cookie from workatastartup.com
# How to get it:
#   1. Open workatastartup.com in Chrome, log in
#   2. DevTools → Network → any request → Headers → Request Headers → Cookie
#   3. Copy the entire cookie string and paste it below
YC_SESSION_COOKIE=_bf_session_exists=...; _sso.key=...; _bf_session_key=...

# Set to 1 to print raw Inertia response structure (useful first time to verify field names)
# DEBUG=1
